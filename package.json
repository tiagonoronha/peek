{
  "name": "peek",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "prebuild": "npm run typecheck && npm run lint",
    "build": "tauri build",
    "notarize-dmg": "xcrun notarytool submit src-tauri/target/release/bundle/dmg/*.dmg --apple-id \"$APPLE_ID\" --password \"$APPLE_PASSWORD\" --team-id \"$APPLE_TEAM_ID\" --wait && xcrun stapler staple src-tauri/target/release/bundle/dmg/*.dmg",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup-icon": "tauri-liquid-icon --icon ./AppIcon.icon --output ./src-tauri/resources && sips -s format png --resampleWidth 256 ./src-tauri/resources/AppIcon.icns --out /tmp/peek-icon-full.png && sips --cropOffset 24 24 --cropToHeightWidth 208 208 /tmp/peek-icon-full.png --out ./src/assets/app-icon.png"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "home-assistant-js-websocket": "^9.6.0",
    "lucide-react": "^0.575.0",
    "mitt": "^3.0.1",
    "normalize-url": "^9.0.0",
    "p-retry": "^7.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "use-debounce": "^10.1.0",
    "valid-url": "^1.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tauri-apps/cli": "^2",
    "@types/eslint__js": "^8.42.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/valid-url": "^1.0.7",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "tauri-liquid-icon": "^1.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.0.4"
  }
}
